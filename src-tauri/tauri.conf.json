{
  "$schema": "https://raw.githubusercontent.com/nicedoc/json-schema/main/tauri2.schema.json",
  "productName": "OpenSim Workbench",
  "version": "0.1.0",
  "identifier": "com.opensim.workbench",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../app && npm run dev",
    "beforeBuildCommand": "cd ../app && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSim Workbench",
        "label": "main",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
